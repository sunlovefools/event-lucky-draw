{
  "name": "event-lucky-draw",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-prewarm.mjs",
    "dev:hot": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:new": "supabase migration new",
    "db:migrate": "supabase db push",
    "db:status": "supabase migration list",
    "db:reset": "supabase db reset",
    "db:clear-non-admin:local": "supabase db query --local --file scripts/clear-non-admin-data.sql",
    "db:clear-non-admin:linked": "supabase db query --linked --file scripts/clear-non-admin-data.sql",
    "seed:admin": "node scripts/create-admin-seed.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "html5-qrcode": "^2.3.8",
    "next": "^15.0.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.1",
    "supabase": "^2.109.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
